<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout du champ Atelier sur l'OF -->
    <record id="view_mrp_production_form_inherit_fma_atelier" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.fma.atelier</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_id']" position="after">
                <field name="atelier_id"
                       options="{'no_create_edit': False}"
                       placeholder="Atelier de production"/>
            </xpath>
        </field>
    </record>

    <!-- Ajout du champ Atelier dans la liste des OF -->
    <record id="view_mrp_production_tree_inherit_fma_atelier" model="ir.ui.view">
        <field name="name">mrp.production.tree.inherit.fma.atelier</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="atelier_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Filtre et regroupement Atelier dans la recherche OF -->
    <record id="view_mrp_production_filter_inherit_fma_atelier" model="ir.ui.view">
        <field name="name">mrp.production.search.inherit.fma.atelier</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="atelier_id"/>
            </xpath>
            <xpath expr="//group" position="inside">
                <filter name="group_by_atelier_id"
                        string="Atelier"
                        context="{'group_by':'atelier_id'}"/>
            </xpath>
        </field>
    </record>
</odoo>
