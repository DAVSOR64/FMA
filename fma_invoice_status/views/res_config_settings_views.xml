<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.fma.customer.outstanding</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@id=('languages')]" position="after">
                <h2>Import Invoice File</h2>
                <div class="row mt-16 o_settings_container" name="sftp_server_configurations_container">
                    <div class="col-12 col-lg-6 o_setting_box" id="sftp_server_configurations_box">
                        <div class="o_setting_right_pane" id="sftp_settings">
                            <span class="o_form_label">SFTP server credentials</span>
                            <div class="text-muted">
                                Setup the SFTP server configurations for file import.
                            </div>
                            <div class="content-group" id="sftp_settings_group" >
                                <div class="mt16 row">
                                    <label for="sftp_host_invoice_status" string="SFTP Server Host" class="col-5 o_light_label"/>
                                    <field name="sftp_host_invoice_status" class="col-7"/>
                                    <label for="sftp_username_invoice_status" string="SFTP Server Username" class="col-5 o_light_label"/>
                                    <field name="sftp_username_invoice_status" class="col-7"/>
                                    <label for="sftp_password_invoice_status" string="SFTP Server Password" class="col-5 o_light_label"/>
                                    <field name="sftp_password_invoice_status" class="col-7"/>
                                    <label for="sftp_file_path_invoice_status" string="SFTP Server File Path" class="col-5 o_light_label"/>
                                    <field name="sftp_file_path_invoice_status" class="col-7"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
