<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_delay_mail" model="ir.ui.view">
        <field name="name">stock.picking.form.delay.mail</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_delay_email"
                        type="object"
                        string="Info retard"
                        class="btn-primary"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <group string="Information retard" name="delay_mail_info" invisible="1">
                    <field name="delay_sale_order_id"/>
                    <field name="delay_arc"/>
                    <field name="delay_ref_client"/>
                    <field name="delay_initial_date"/>
                    <field name="delay_initial_week"/>
                    <field name="delay_new_date"/>
                    <field name="delay_new_week"/>
                    <field name="delay_motif"/>
                    <field name="delay_designation"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
