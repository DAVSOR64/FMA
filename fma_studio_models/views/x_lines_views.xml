<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_studio_lines" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.studio.lines</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Lignes (Studio)" name="studio_lines">
                    <field name="x_studio_one2many_field_3hq_1ih7eucbu">
                        <list editable="bottom">
                            <field name="x_studio_sequence" widget="handle"/>
                            <field name="x_name"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_form_inherit_studio_lines" model="ir.ui.view">
        <field name="name">account.move.form.inherit.studio.lines</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Lignes (Studio)" name="studio_lines">
                    <field name="x_studio_one2many_field_kJvUD">
                        <list editable="bottom">
                            <field name="x_studio_sequence" widget="handle"/>
                            <field name="x_name"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
