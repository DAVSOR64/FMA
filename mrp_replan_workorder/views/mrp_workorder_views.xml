<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_inherit_macro_forced_end" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.macro_forced_end</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_finished']" position="after">
                <field name="macro_forced_end" readonly="1"/>
            </xpath>
        </field>
    </record>
    <record id="mrp_production_workorder_tree_inherit_macro" model="ir.ui.view">
        <field name="name">mrp.production.workorder.tree.inherit.macro_planned_start</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="macro_planned_start" optional="show" string="Macro (début planifié)"/>
            </xpath>
        </field>
    </record>
    <record id="mrp_production_form_replan_button" model="ir.ui.view">
        <field name="name">mrp.production.form.replan.preview.button</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_replan_preview" type="object" string="Recalculer planning" class="btn-primary"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_replan_preview_wizard_form" model="ir.ui.view">
        <field name="name">mrp.replan.preview.wizard.form</field>
        <field name="model">mrp.replan.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Prévisualisation recalcul OF">
                <group>
                    <field name="production_id"/>
                    <field name="summary_html" widget="html" nolabel="1"/>
                    <field name="preview_json" invisible="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
