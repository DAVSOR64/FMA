
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_replan_preview_wizard_form" model="ir.ui.view">
        <field name="name">mrp.replan.preview.wizard.form</field>
        <field name="model">mrp.replan.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Prévisualisation recalcul OF">
                <group>
                    <field name="production_id"/>
                    <field name="summary_html" widget="html" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
