<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- Vue liste Planning OF avec N° MTN                                  -->
    <!-- ================================================================== -->

    <record id="view_mrp_production_planning_tree" model="ir.ui.view">
        <field name="name">mrp.production.planning.tree</field>
        <field name="model">mrp.production</field>
        <field name="arch" type="xml">
            <tree string="Planning OF"
                  create="false" edit="true" delete="false"
                  decoration-danger="date_deadline and date_finished and date_finished &gt; date_deadline"
                  decoration-muted="state in ('done','cancel')">
                <field name="name" string="N° OF"/>
                <field name="product_id" string="Produit"/>
                <field name="product_qty" string="Qté" optional="show"/>
                <field name="date_start" string="Début fab." widget="date"/>
                <field name="date_finished" string="Fin fab." widget="date"/>
                <field name="macro_forced_end" string="Fin forcée" widget="date" optional="show"/>
                <field name="date_deadline" string="Deadline" widget="date" optional="show"/>
                <field name="state" string="État"
                       widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'progress'"
                       decoration-info="state in ('confirmed','planned')"
                       decoration-muted="state == 'cancel'"/>
                <button name="action_replanifier" type="object"
                        string="⟳ Replanifier" icon="fa-refresh"
                        class="btn-warning btn-sm"
                        attrs="{'invisible': [('state', 'in', ['done', 'cancel'])]}"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Action Planning OF (Gantt + liste)                                 -->
    <!-- ================================================================== -->

    <record id="action_mrp_production_planning" model="ir.actions.act_window">
        <field name="name">Planning OF</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state','not in',['done','cancel'])]</field>
        <field name="context">{}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'tree', 'view_id': ref('view_mrp_production_planning_tree')}),
        ]"/>
    </record>

</odoo>
