<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fma_atelier_tree" model="ir.ui.view">
        <field name="name">fma.atelier.tree</field>
        <field name="model">fma.atelier</field>
        <field name="arch" type="xml">
            <tree string="Ateliers" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="calendar_id" optional="show"/>
                <field name="responsible_id" optional="show"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_fma_atelier_form" model="ir.ui.view">
        <field name="name">fma.atelier.form</field>
        <field name="model">fma.atelier</field>
        <field name="arch" type="xml">
            <form string="Atelier">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="calendar_id"/>
                            <field name="responsible_id"/>
                            <field name="color"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fma_atelier_search" model="ir.ui.view">
        <field name="name">fma.atelier.search</field>
        <field name="model">fma.atelier</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Actif" name="active" domain="[('active','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="action_fma_atelier" model="ir.actions.act_window">
        <field name="name">Ateliers</field>
        <field name="res_model">fma.atelier</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
