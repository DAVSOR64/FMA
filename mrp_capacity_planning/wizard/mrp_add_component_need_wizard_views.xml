<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_add_component_need_wizard_form" model="ir.ui.view">
        <field name="name">mrp.add.component.need.wizard.form</field>
        <field name="model">mrp.add.component.need.wizard</field>
        <field name="arch" type="xml">
            <form string="Ajouter un besoin">
                <group>
                    <field name="production_id"/>
                    <field name="product_id" options="{'no_create': False}"/>
                    <field name="product_qty"/>
                    <field name="product_uom_id"/>
                    <field name="date_planned"/>
                    <field name="reason"/>
                    <field name="note" placeholder="Ex : casse vitrage, oubli, remplacement..."/>
                </group>
                <footer>
                    <button name="action_add_need" string="Ajouter le besoin" type="object" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mrp_add_component_need_wizard" model="ir.actions.act_window">
        <field name="name">Ajouter un besoin</field>
        <field name="res_model">mrp.add.component.need.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
