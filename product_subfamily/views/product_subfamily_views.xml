<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_subfamily_tree" model="ir.ui.view">
        <field name="name">product.subfamily.tree</field>
        <field name="model">product.subfamily</field>
        <field name="arch" type="xml">
            <list string="Sous-familles">
                <field name="sequence" widget="handle"/>
                <field name="family_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_product_subfamily_form" model="ir.ui.view">
        <field name="name">product.subfamily.form</field>
        <field name="model">product.subfamily</field>
        <field name="arch" type="xml">
            <form string="Sous-famille">
                <sheet>
                    <group>
                        <field name="family_id"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_subfamily" model="ir.actions.act_window">
        <field name="name">Sous-familles produits</field>
        <field name="res_model">product.subfamily</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
