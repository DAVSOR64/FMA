
<odoo>
    <record id="view_mrp_recalc_planif_wizard_form" model="ir.ui.view">
        <field name="name">mrp.recalc.planif.wizard.form</field>
        <field name="model">mrp.recalc.planif.wizard</field>
        <field name="arch" type="xml">
            <form string="Recalcul planification">
                <sheet>
                    <div style="width:100%; min-width:900px;">
                        <field name="production_id" invisible="1"/>
                        <field name="preview_html" nolabel="1" widget="html" readonly="1"/>
                        <div style="height:12px;"/>
                        <field name="po_html" nolabel="1" widget="html" readonly="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Valider" class="btn-primary"/>
                    <button string="Abandon" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
