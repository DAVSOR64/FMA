<odoo>
    <record id="view_mrp_production_form_fma_unified_buttons_v4" model="ir.ui.view">
        <field name="name">mrp.production.form.fma.unified.buttons.v4</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_resequence_fma" type="object" string="Réordonner FMA" class="btn-secondary"/>
                <button name="action_open_recalc_planif_popup" type="object" string="Recalcul planif" class="btn-secondary"/>
            </xpath>
            <xpath expr="//field[@name='workorder_ids']" position="attributes">
                <attribute name="context">{'default_order': 'op_sequence asc, id asc'}</attribute>
            </xpath>
        </field>
    </record>

    <record id="mrp_production_action_batch_resequence_and_recompute_v4" model="ir.actions.server">
        <field name="name">Réordonner FMA + recalculer macro (OF non démarrés)</field>
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = model.action_batch_resequence_and_recompute_non_started()</field>
    </record>
</odoo>
