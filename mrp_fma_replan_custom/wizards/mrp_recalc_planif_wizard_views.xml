<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_recalc_planif_wizard_form" model="ir.ui.view">
        <field name="name">mrp.recalc.planif.wizard.form.custom.finish</field>
        <field name="model">mrp.recalc.planif.wizard</field>
        <field name="arch" type="xml">
            <form string="Recalcul planification">
                <sheet>
                    <field name="production_id" invisible="1"/>
                    <field name="preview_html" nolabel="1" widget="html"/>
                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
