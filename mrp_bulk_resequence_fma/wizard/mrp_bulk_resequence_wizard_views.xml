<odoo>
    <record id="view_mrp_bulk_resequence_wizard_form" model="ir.ui.view">
        <field name="name">mrp.bulk.resequence.wizard.form</field>
        <field name="model">mrp.bulk.resequence.wizard</field>
        <field name="arch" type="xml">
            <form string="Réordonner opérations FMA">
                <group>
                    <field name="production_ids" widget="many2many_tags" readonly="1"/>
                    <field name="skip_started_info" readonly="1"/>
                    <field name="operation_order_text" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Appliquer" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
