<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_production_form_workorder_operator_time" model="ir.ui.view">
        <field name="name">mrp.production.form.workorder.operator.time</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workorder_ids']//field[@name='duration_expected']" position="after">
                <field name="x_operator_time_spent" string="Temps opérateur" widget="float_time" readonly="1" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
