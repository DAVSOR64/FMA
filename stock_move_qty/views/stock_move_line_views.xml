<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_line_tree_inherit_qty_before_after" model="ir.ui.view">
        <field name="name">stock.move.line.tree.qty.before.after</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_stock_move_line_detailed_operation_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quantity']" position="after">
                <field name="x_move_type" optional="show"/>
                <field name="qty_tracked_location_id" optional="show"/>
                <field name="qty_before_move" optional="show"/>
                <field name="qty_after_move" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
