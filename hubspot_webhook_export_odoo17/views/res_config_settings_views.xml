<odoo>
    <record id="res_config_settings_view_form_hubspot_export" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.hubspot.export</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Export HubSpot" string="Export HubSpot" name="hubspot_export">
                    <block title="Connexion webhook n8n / HubSpot">
                        <setting string="URL webhook">
                            <field name="hubspot_webhook_url" placeholder="https://n8n.showroom-janneau.com/webhook/fma-f2m"/>
                        </setting>
                        <setting string="Identifiant Basic Auth">
                            <field name="hubspot_basic_auth_login" placeholder="JanneauFMAF2m"/>
                        </setting>
                        <setting string="Mot de passe Basic Auth">
                            <field name="hubspot_basic_auth_password" password="1" placeholder="Mot de passe"/>
                        </setting>
                        <setting string="Périmètre export">
                            <field name="hubspot_export_only_updated"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
