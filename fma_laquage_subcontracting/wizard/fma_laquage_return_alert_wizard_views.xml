<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fma_laquage_return_alert_wizard_form" model="ir.ui.view">
        <field name="name">fma.laquage.return.alert.wizard.form</field>
        <field name="model">fma.laquage.return.alert.wizard</field>
        <field name="arch" type="xml">
            <form string="Retour laquage">
                <sheet>
                    <field name="alert_type" invisible="1"/>
                    <div class="alert alert-success" role="alert" invisible="alert_type != 'success'">
                        <field name="message" nolabel="1" readonly="1"/>
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="alert_type != 'warning'">
                        <field name="message" nolabel="1" readonly="1"/>
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="alert_type != 'danger'">
                        <field name="message" nolabel="1" readonly="1"/>
                    </div>
                    <group>
                        <field name="production_id" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_replanifier_of" type="object" string="Replanifier l'OF" class="btn-primary" invisible="alert_type == 'success'"/>
                    <button name="action_close_reload" type="object" string="Fermer" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
