<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fma_laquage_plan_wizard_form" model="ir.ui.view">
        <field name="name">fma.laquage.plan.wizard.form</field>
        <field name="model">fma.laquage.plan.wizard</field>
        <field name="arch" type="xml">
            <form string="Planifier le laquage">
                <group>
                    <field name="production_id"/>
                    <field name="subcontractor_id"/>
                    <field name="slot_id" domain="[('subcontractor_id', '=', subcontractor_id), ('active', '=', True)]"/>
                    <field name="workcenter_id"/>
                    <field name="replan_now"/>
                    <field name="create_purchase"/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Valider" class="btn-primary"/>
                    <button string="Annuler" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
