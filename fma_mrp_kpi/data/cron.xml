<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_mrp_daily_snapshot" model="ir.cron">
        <field name="name">FMA - Visu atelier quotidienne (23H30)</field>
        <field name="model_id" ref="model_mrp_daily_snapshot"/>
        <field name="state">code</field>
        <field name="code">model.cron_compute_daily_snapshot()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
        <field name="nextcall" eval="(datetime.now()).strftime('%Y-%m-%d 23:30:00')"/>
    </record>
</odoo>
